  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "filesystem": {
      "allowWrite": ["./", "/tmp/claude-build"],
      "denyRead": [
        "./keys",
        "./.env",
        "./.env.local",
        "~/.ssh",
        "~/.aws",
        "~/.gnupg",
        "~/.config/gcloud"
      ]
    },
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "crates.io",
        "static.crates.io",
        "index.crates.io",
        "registry.npmjs.org",
        "pypi.org",
        "files.pythonhosted.org",
        "docs.rs",
        "doc.rust-lang.org",
        "docs.anthropic.com"
      ],
      "allowLocalBinding": true
    }
  },
  "autoMode": {
    "environment": [
      "Organization: personal development, user jadenfix on Mac mini",
      "Source control: github.com/jadenfix/deets (Aether blockchain monorepo)",
      "Trusted domains: github.com, api.github.com, docs.anthropic.com, docs.rs, doc.rust-lang.org",
      "Package registries: crates.io, static.crates.io, index.crates.io, registry.npmjs.org, pypi.org, files.pythonhosted.org",
      "Local services: JSON-RPC on ports 8545-8548, P2P gossip on 9000-9003, Prometheus on 9090, Grafana on 3000",
      "Sandbox is ON: writes limited to repo + /tmp/claude-build, no secret paths readable, network limited to listed domains",
      "PROHIBITED: force-push, cargo/npm publish, kubectl/helm/terraform apply, wget, curl downloads"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-tool-use.sh"
          }
        ]
      }
    ]
  }
