FROM rust:1.90-slim AS chef
RUN cargo install cargo-chef --locked
WORKDIR /build

FROM chef AS planner
COPY Cargo.toml Cargo.lock ./
COPY crates ./crates
COPY ai-mesh ./ai-mesh
RUN cargo chef prepare --recipe-path recipe.json

FROM chef AS builder

RUN apt-get update && apt-get install -y \
    pkg-config \
    clang \
    llvm-dev \
    libclang-dev \
    && rm -rf /var/lib/apt/lists/*

COPY --from=planner /build/recipe.json recipe.json
RUN cargo chef cook --release --recipe-path recipe.json

COPY Cargo.toml Cargo.lock ./
COPY crates ./crates
COPY ai-mesh ./ai-mesh
RUN cargo build --release --bin aether-indexer

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

RUN groupadd --gid 1000 aether && \
    useradd --uid 1000 --gid aether --shell /bin/false aether

WORKDIR /app

COPY --from=builder /build/target/release/aether-indexer /usr/local/bin/
RUN mkdir -p /data && chown -R aether:aether /data

EXPOSE 8080

USER aether

ENTRYPOINT ["aether-indexer"]
